# Convex — get these from https://dashboard.convex.dev after running `npx convex dev`
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Admin auth — set a strong password and a random secret
ADMIN_PASSWORD=your-admin-password
ADMIN_SECRET=your-random-secret-at-least-32-chars

# Public site URL — used for OG image and canonical URLs
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Contact form (Resend — https://resend.com)
RESEND_API_KEY=re_your_api_key
CONTACT_EMAIL=you@yourdomain.com
CONTACT_DOMAIN=yourdomain.com
